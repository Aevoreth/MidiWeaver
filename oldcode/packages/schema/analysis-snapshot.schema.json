{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://midiweaver.dev/schema/analysis-snapshot.json",
  "title": "AnalysisSnapshot",
  "type": "object",
  "required": [
    "song_id",
    "source_filename",
    "ppq",
    "bar_count",
    "estimated_bpm",
    "bpm_range",
    "time_sig"
  ],
  "properties": {
    "song_id": { "type": "string" },
    "source_filename": { "type": "string" },
    "ppq": { "type": "integer", "minimum": 1 },
    "bar_count": { "type": "number", "minimum": 0 },
    "estimated_bpm": { "type": "number", "minimum": 0 },
    "bpm_range": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "time_sig": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "minItems": 2,
      "maxItems": 2
    },
    "key": { "type": ["string", "null"] },
    "tempo_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/TempoEvent" }
    },
    "time_sig_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/TimeSignatureEvent" }
    },
    "track_summaries": {
      "type": "array",
      "items": { "$ref": "#/$defs/TrackSummary" }
    },
    "tracks": {
      "type": "array",
      "items": { "$ref": "#/$defs/TrackData" }
    },
    "trim_start_tick": { "type": "integer", "minimum": 0 },
    "trim_end_tick": { "type": ["integer", "null"], "minimum": 0 },
    "loop_boundaries": {
      "type": "array",
      "items": { "type": "integer" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "TempoEvent": {
      "type": "object",
      "required": ["tick", "bpm"],
      "properties": {
        "tick": { "type": "integer" },
        "bpm": { "type": "number" }
      }
    },
    "TimeSignatureEvent": {
      "type": "object",
      "required": ["tick", "numerator", "denominator"],
      "properties": {
        "tick": { "type": "integer" },
        "numerator": { "type": "integer" },
        "denominator": { "type": "integer" }
      }
    },
    "TrackSummary": {
      "type": "object",
      "required": ["track_id", "name"],
      "properties": {
        "track_id": { "type": "string" },
        "name": { "type": "string" },
        "channel": { "type": ["integer", "null"] },
        "program": { "type": ["integer", "null"] },
        "is_drum": { "type": "boolean" },
        "note_min": { "type": ["integer", "null"] },
        "note_max": { "type": ["integer", "null"] },
        "note_count": { "type": "integer" },
        "density_per_bar": { "type": "number" },
        "quantize_enabled": { "type": "boolean" },
        "quantize_strength": { "type": "number" },
        "snap_override": { "type": "string" }
      }
    },
    "NoteEvent": {
      "type": "object",
      "required": ["pitch", "start_tick", "duration_ticks"],
      "properties": {
        "pitch": { "type": "integer", "minimum": 0, "maximum": 127 },
        "start_tick": { "type": "integer" },
        "duration_ticks": { "type": "integer", "minimum": 1 },
        "velocity": { "type": "integer", "minimum": 0, "maximum": 127 },
        "channel": { "type": "integer", "minimum": 0, "maximum": 15 }
      }
    },
    "TrackData": {
      "type": "object",
      "required": ["track_id", "name"],
      "properties": {
        "track_id": { "type": "string" },
        "name": { "type": "string" },
        "channel": { "type": ["integer", "null"] },
        "program": { "type": ["integer", "null"] },
        "is_drum": { "type": "boolean" },
        "notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/NoteEvent" }
        },
        "mute": { "type": "boolean" },
        "solo": { "type": "boolean" },
        "volume": { "type": "number" },
        "master_track_id": { "type": ["string", "null"] },
        "snap_override": { "type": "string" },
        "quantize_enabled": { "type": "boolean" },
        "quantize_strength": { "type": "number" }
      }
    }
  }
}
