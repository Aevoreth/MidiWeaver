{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MidiWeaver",
  "version": "0.1.0",
  "identifier": "dev.midiweaver.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MidiWeaver",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/midiweaver-engine"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
